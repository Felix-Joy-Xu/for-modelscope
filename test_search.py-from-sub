import os as _os
try:
    from _secrets import GITHUB_TOKEN
except ImportError:
    GITHUB_TOKEN = _os.environ.get("GITHUB_TOKEN", "")

import requests

token = GITHUB_TOKEN
headers = {'Authorization': f'token {token}', 'Accept': 'application/vnd.github.v3+json', 'User-Agent': 'test'}

queries = [
    'github copilot writing code repo:microsoft/vscode created:2024-01-01..2024-12-31',
    'github copilot code review repo:microsoft/vscode created:2024-01-01..2024-12-31',
    'copilot writing code repo:facebook/react created:2024-01-01..2024-12-31',
    'vibe coding repo:vercel/next.js created:2024-01-01..2024-12-31',
    'aider commit code repo:nodejs/node created:2024-01-01..2024-12-31',
    '"github copilot" writing code function in:body repo:microsoft/vscode created:2024-01-01..2024-12-31',
    '"github copilot" writing code function in:body repo:facebook/react created:2024-01-01..2024-12-31',
]
for q in queries:
    r = requests.get('https://api.github.com/search/issues', headers=headers, params={'q': q, 'per_page': 1})
    data = r.json()
    total = data.get('total_count', 0)
    print(f'{total:>5}条 | {q[:80]}')
